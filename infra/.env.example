# ======================
# Brooks Environment Variables
# Copy to .env and fill in values
# ======================

# --- Database ---
DB_URL=jdbc:postgresql://postgres:5432/brooks
DB_USERNAME=brooks
DB_PASSWORD=brooks_local

# --- Auth0 ---
AUTH0_DOMAIN=tenant.example.auth0.com
AUTH0_AUDIENCE=https://api.brooks.example.com
AUTH0_CLIENT_ID=replace-me
AUTH0_CLIENT_SECRET=replace-me
# --- GCP ---
GCP_PROJECT_ID=your-gcp-project
GCS_BUCKET=brooks-media
GCS_CREDENTIALS_JSON=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Bank of Georgia iPay ---
BOG_IPAY_CLIENT_ID=your_bog_ipay_client_id
BOG_IPAY_SECRET_KEY=your_bog_ipay_secret_key
BOG_IPAY_BASE_URL=https://ipay.ge/opay/api/v1

# --- PayPal ---
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# --- App ---
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_EMAILS=admin@example.com
PLATFORM_FEE_PERCENT=10
PLACE_IMAGE_MAX_COUNT=4
MEDIA_MAX_UPLOAD_SIZE_MB=10
PAYOUT_SCHEDULE_CRON=0 0 2 * * MON
RANKING_REFRESH_CRON=0 0 3 * * *
MEMORY_UNLOCK_RADIUS_METERS=100

# Hex-encoded AES key for encrypting stored AI provider keys.
# Generate with: openssl rand -hex 32
AI_KEY_ENCRYPTION_SECRET=replace_with_64_hex_chars

# --- Example Creator Seed ---
SEED_EXAMPLE_ENABLED=true
SEED_EXAMPLE_AUTH0_SUBJECT=seed|brooks-editorial
SEED_EXAMPLE_EMAIL=example.creator@brooks.local
SEED_EXAMPLE_USERNAME=brooks-editorial
SEED_EXAMPLE_DISPLAY_NAME=Brooks Editorial
SEED_EXAMPLE_BIO=Curated city guides, neighborhood routes, and dependable local picks for first-time and repeat visitors.
SEED_EXAMPLE_AVATAR_URL=https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=320&q=80
SEED_EXAMPLE_REGION=Tbilisi, Georgia
SEED_EXAMPLE_INTERESTS=coffee, design, city walks, food
SEED_EXAMPLE_LATITUDE=41.7151
SEED_EXAMPLE_LONGITUDE=44.8271
SEED_EXAMPLE_FOLLOWER_COUNT=12400
SEED_EXAMPLE_FOLLOWING_COUNT=215
SEED_EXAMPLE_VERIFIED=true
SEED_EXAMPLE_GUIDE_TITLE=48 Hours in Tbilisi
SEED_EXAMPLE_GUIDE_SUMMARY=A compact, design-forward Tbilisi guide with reliable stops for coffee, food, and a walkable neighborhood route.
SEED_EXAMPLE_GUIDE_CITY=Tbilisi
SEED_EXAMPLE_GUIDE_COUNTRY=Georgia
SEED_EXAMPLE_GUIDE_COVER_IMAGE_URL=https://images.unsplash.com/photo-1565008576549-57569a49371d?auto=format&fit=crop&w=1200&q=80
SEED_EXAMPLE_GUIDE_PRICE_CENTS=1900
SEED_EXAMPLE_GUIDE_CURRENCY=USD
SEED_EXAMPLE_GUIDE_TAGS=city-break,coffee,design,food
SEED_EXAMPLE_DAY_TITLE=Day 1 Highlights
SEED_EXAMPLE_DAY_DESCRIPTION=A focused first-day route with one anchor stop and enough context to orient new visitors quickly.
SEED_EXAMPLE_BLOCK_TITLE=Neighborhood Route
SEED_EXAMPLE_BLOCK_DESCRIPTION=Start in a central creative district, then move outward through one dependable stop worth building the day around.
SEED_EXAMPLE_BLOCK_TYPE=ACTIVITY
SEED_EXAMPLE_PLACE_NAME=Fabrika Tbilisi
SEED_EXAMPLE_PLACE_DESCRIPTION=A reliable anchor for coffee, co-working, and a walkable neighborhood start with other stops nearby.
SEED_EXAMPLE_PLACE_ADDRESS=8 Ninoshvili Street, Tbilisi, Georgia
SEED_EXAMPLE_PLACE_LATITUDE=41.7098
SEED_EXAMPLE_PLACE_LONGITUDE=44.8015
SEED_EXAMPLE_PLACE_CATEGORY=Creative Hub
SEED_EXAMPLE_PLACE_PRICE_LEVEL=2
SEED_EXAMPLE_PLACE_IMAGE_URL=https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=900&q=80

# --- Docker Registry (production) ---
DOCKER_REGISTRY=us-docker.pkg.dev/your-project/brooks
IMAGE_TAG=latest
DOMAIN=localhost
